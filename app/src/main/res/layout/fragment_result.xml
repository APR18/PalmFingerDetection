<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Capture Results"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Success Icon / Status -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✓ All fingers captured successfully"
            android:textSize="18sp"
            android:textColor="#4CAF50"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- ─── Score Cards ─── -->

        <!-- Blur Score Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Blur Score"
                    android:textSize="16sp"
                    android:textColor="#B0B0B0" />

                <TextView
                    android:id="@+id/blurScoreValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Blur Quality Indicator -->
        <TextView
            android:id="@+id/blurQualityText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Image Quality: Sharp"
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:gravity="end"
            android:layout_marginBottom="12dp"
            android:paddingEnd="8dp" />

        <!-- Brightness Score Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Brightness Score"
                    android:textSize="16sp"
                    android:textColor="#B0B0B0" />

                <TextView
                    android:id="@+id/brightnessScoreValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Brightness Condition -->
        <TextView
            android:id="@+id/brightnessConditionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lighting: Normal"
            android:textSize="14sp"
            android:textColor="#4CAF50"
            android:gravity="end"
            android:layout_marginBottom="12dp"
            android:paddingEnd="8dp" />

        <!-- Focus Distance Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Focus Distance"
                    android:textSize="16sp"
                    android:textColor="#B0B0B0" />

                <TextView
                    android:id="@+id/focusDistanceValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── Device Info Section ─── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Device Information"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" />

        <!-- Device ID -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Device ID"
                    android:textSize="14sp"
                    android:textColor="#B0B0B0" />

                <TextView
                    android:id="@+id/deviceIdValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Camera Type"
                    android:textSize="14sp"
                    android:textColor="#B0B0B0"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/cameraTypeValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hand Detected"
                    android:textSize="14sp"
                    android:textColor="#B0B0B0"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/handDetectedValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── Captured Images Section ─── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Captured Images"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" />

        <!-- Container for dynamically added image thumbnails -->
        <LinearLayout
            android:id="@+id/thumbnailContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- No images fallback text -->
        <TextView
            android:id="@+id/noImagesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No images found in Finger Data folder"
            android:textSize="14sp"
            android:textColor="#B0B0B0"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- ─── Done Button ─── -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/doneButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start New Scan"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:backgroundTint="#4CAF50" />

    </LinearLayout>
</ScrollView>